  </tr>
  <tr>
    <td>RNF1</td>
    <td>Usabilidad</td>
    <td class="status-completado">Completado</td>
    <td>Interfaz moderna e intuitiva con dise&ntilde;o responsive para m&oacute;viles.</td>
  </tr>
  <tr>
    <td>RNF2</td>
    <td>Rendimiento</td>
    <td class="status-completado">Completado</td>
    <td>Respuestas menores a 3 segundos. Cache de disponibilidad de API.</td>
  </tr>
  <tr>
    <td>RNF3</td>
    <td>Seguridad</td>
    <td class="status-completado">Completado</td>
    <td>Hashing SHA-256, PDO prepared statements, validaci&oacute;n de entrada.</td>
  </tr>
  <tr>
    <td>RNF4</td>
    <td>Disponibilidad</td>
    <td class="status-parcial">Parcial</td>
    <td>PWA offline funcional. Servidor de producci&oacute;n pendiente.</td>
  </tr>
  <tr>
    <td>RNF5</td>
    <td>Compatibilidad</td>
